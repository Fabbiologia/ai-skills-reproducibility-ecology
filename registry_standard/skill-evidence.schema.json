{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/ai-skill-evidence/0.1.0/schema.json",
  "title": "AI Skill Evidence Manifest",
  "description": "Proposed minimum evidence record for a versioned analysis skill.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "version",
    "skill_file",
    "domain",
    "summary",
    "contract",
    "controls",
    "environment",
    "validation",
    "provenance",
    "known_limitations"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "0.1.0"},
    "name": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 64},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"},
    "skill_file": {"type": "string", "minLength": 1},
    "domain": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "summary": {"type": "string", "minLength": 20},
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputs", "method", "outputs"],
      "properties": {
        "inputs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dataset", "required_columns", "missing_data"],
          "properties": {
            "dataset": {"type": "string", "minLength": 1},
            "required_columns": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
            "missing_data": {"type": "string", "minLength": 1}
          }
        },
        "method": {"type": "string", "minLength": 20},
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "unit", "absolute_tolerance"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "type": {"enum": ["number", "integer", "string", "boolean"]},
              "unit": {"type": "string", "minLength": 1},
              "absolute_tolerance": {"type": "number", "exclusiveMinimum": 0}
            }
          }
        }
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stochastic", "fixed"],
      "properties": {
        "stochastic": {"type": "boolean"},
        "fixed": {"type": "object", "minProperties": 1}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "language_version", "packages"],
      "properties": {
        "language": {"type": "string", "minLength": 1},
        "language_version": {"type": "string", "minLength": 1},
        "packages": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string"}}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["self_consistency", "reference_tests", "coherence_checks"],
      "properties": {
        "self_consistency": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum_runs", "minimum_modal_agreement"],
          "properties": {
            "minimum_runs": {"type": "integer", "minimum": 5},
            "minimum_modal_agreement": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "reference_tests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["dataset", "output", "expected", "absolute_tolerance"],
            "properties": {
              "dataset": {"type": "string", "minLength": 1},
              "output": {"type": "string", "minLength": 1},
              "expected": {"type": ["number", "integer", "string", "boolean"]},
              "absolute_tolerance": {"type": "number", "exclusiveMinimum": 0}
            }
          }
        },
        "coherence_checks": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authors", "license", "source_study"],
      "properties": {
        "authors": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "license": {"type": "string", "minLength": 1},
        "source_study": {"type": "string", "minLength": 1}
      }
    },
    "known_limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 10}},
    "token_cost": {
      "type": "object",
      "description": "Optional cost metadata measured during validation. Static cost is the fixed size of the skill prompt; dynamic cost is the typical per-run generation. Reported so a user can weigh the cost of an entry.",
      "additionalProperties": false,
      "properties": {
        "static_prompt_chars": {"type": "integer", "minimum": 0},
        "static_prompt_tokens": {"type": "integer", "minimum": 0},
        "tokenizer": {"type": "string", "minLength": 1},
        "median_completion_tokens": {"type": "number", "minimum": 0},
        "measured_on_model": {"type": "string", "minLength": 1}
      }
    },
    "model_compatibility": {
      "type": "array",
      "description": "Optional record of the models the skill was validated on and whether each reached the reference, supporting a cross-model compatibility matrix. A skill that passes on one model is not assumed to pass on all.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["model", "passed"],
        "properties": {
          "model": {"type": "string", "minLength": 1},
          "modal_agreement": {"type": "number", "minimum": 0, "maximum": 1},
          "reference_validity": {"type": "number", "minimum": 0, "maximum": 1},
          "passed": {"type": "boolean"}
        }
      }
    }
  }
}
